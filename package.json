{
  "name": "studysync",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @studysync/api exec prisma generate",
    "db:migrate": "pnpm --filter @studysync/api exec prisma migrate dev",
    "db:push": "pnpm --filter @studysync/api exec prisma db push",
    "db:seed": "pnpm --filter @studysync/api exec prisma db seed",
    "db:studio": "pnpm --filter @studysync/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}
